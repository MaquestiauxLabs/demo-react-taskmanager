{
  "name": "api",
  "version": "0.1.1",
  "description": "The api for the task manager",
  "keywords": [
    "api",
    "expressjs",
    "prisma",
    "typescript"
  ],
  "homepage": "https://github.com/MaquestiauxLabs/demo-react-taskmanager#readme",
  "bugs": {
    "url": "https://github.com/MaquestiauxLabs/demo-react-taskmanager/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/MaquestiauxLabs/demo-react-taskmanager.git"
  },
  "license": "MIT",
  "author": "Jean-Philippe Maquestiaux",
  "type": "module",
  "main": "dist/server.js",
  "prisma": {
    "seed": "tsx prisma/seed/index.ts",
    "schema": "./server/prisma"
  },
  "scripts": {
    "dev": "tsx watch server.ts",
    "build": "tsc --noEmit false",
    "start": "node dist/server.js",
    "db:start": "docker compose -f ../database/docker-compose.yml up -d",
    "db:stop": "docker compose -f ../database/docker-compose.yml down",
    "db:logs": "docker compose -f ../database/docker-compose.yml logs -f db",
    "db:status": "docker compose -f ../database/docker-compose.yml ps",
    "test": "vitest",
    "test:run": "vitest run",
    "test:watch": "vitest --watch",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "db:test:start": "docker compose -f ../database/docker-compose.test.yml up -d",
    "db:test:stop": "docker compose -f ../database/docker-compose.test.yml down",
    "db:test:reset": "npm run db:test:stop && npm run db:test:start && npm run prisma:push",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"**/*.ts\"",
    "prisma:format": "prisma format",
    "prisma:validate": "prisma validate",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:pull": "prisma db pull",
    "prisma:status": "prisma migrate status",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy",
    "prisma:seed": "prisma db seed",
    "prisma:reset": "prisma migrate reset",
    "prisma:studio": "prisma studio",
    "prisma:sync": "prisma format && prisma validate && prisma generate && prisma db push",
    "prisma:migrate:sync": "prisma format && prisma validate && prisma migrate dev",
    "prisma:maintenance": "prisma format && prisma validate && prisma generate && prisma migrate deploy",
    "swagger": "node -e \"console.log('Swagger UI available at http://localhost:3000/api-docs')\""
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.4.0",
    "@prisma/client": "^7.4.0",
    "cors": "^2.8.6",
    "express": "^5.2.1",
    "pg": "^8.18.0",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.0",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.6",
    "@types/node": "^25.2.3",
    "@types/pg": "^8.16.0",
    "@types/supertest": "^7.2.0",
    "@types/swagger-jsdoc": "^6.0.4",
    "@types/swagger-ui-express": "^4.1.8",
    "@vitest/coverage-v8": "^4.0.18",
    "@vitest/ui": "^4.0.18",
    "dotenv": "^17.3.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^16.4.0",
    "prettier": "^3.8.1",
    "prisma": "^7.4.0",
    "prisma-markdown": "^4.0.0",
    "prisma-zod-generator": "^2.1.4",
    "supertest": "^7.2.2",
    "swagger-ui-express": "^5.0.1",
    "ts-node": "^10.9.2",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.44.1",
    "vitest": "^4.0.18"
  }
}
